generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  FARMER
  COOP_ADMIN
  MFI_AGENT
  SUPERADMIN
}

enum KycStatus {
  PENDING
  VALIDATED
  REJECTED
}


enum LoanStatus {
  EN_COURS
  REMBOURSE
  DEFAUT
  EN_ATTENTE
}

enum NodeStatus {
  LIVE
  OFFLINE
  MAINTENANCE
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         Role
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  farmer           Farmer?
  coopAdmin        CoopAdmin?
  mfiAgent         MFIAgent?
  apiKeys          ApiKey[]
  institutionUsers InstitutionUser[]
}

model Farmer {
  id            String    @id @default(cuid())
  userId        String    @unique
  firstName     String
  lastName      String
  phone         String
  region        String
  village       String
  lat           Float
  lng           Float
  surface       Float
  onboardedAt   DateTime  @default(now())
  kycStatus     KycStatus @default(PENDING)
  photoUrl         String?
  cniUrl           String?
  attestationUrl   String?
  cooperativeId    String?
  blockchainId     String?

  user        User        @relation(fields: [userId], references: [id])
  cooperative Cooperative? @relation(fields: [cooperativeId], references: [id])
  parcelles   Parcelle[]
  loans       Loan[]
  alerts      Alert[]
  creditScore CreditScore?
  iotNodes    IoTNode[]
  weatherHistory WeatherHistory[]
  activities  Activity[]
  messages    Message[]
  creditRequests  CreditRequest[]
  creditDecisions CreditDecision[]

  // Scoring fields
  experienceAnnees  String?
  revenusAnnexes    String?
  historicCredit    String?
}

model CoopAdmin {
  id            String  @id @default(cuid())
  userId        String  @unique
  cooperativeId String? @unique

  user        User         @relation(fields: [userId], references: [id])
  cooperative Cooperative? @relation(fields: [cooperativeId], references: [id])
}

model MFIAgent {
  id     String @id @default(cuid())
  userId String @unique

  user User @relation(fields: [userId], references: [id])
}

model Cooperative {
  id           String   @id @default(cuid())
  name         String
  rccm         String   @unique
  region       String
  filiere      String
  surface      Float
  foundedAt    DateTime
  blockchainId String?
  lat          Float
  lng          Float
  logoUrl      String?
  adminUserId  String?

  institutionId String?
  institution   Institution? @relation(fields: [institutionId], references: [id])

  farmers   Farmer[]
  coopAdmin CoopAdmin?
  iotNode   IoTNode?
  alerts    Alert[]
  weatherHistory WeatherHistory[]
  messages  Message[]
}

model Parcelle {
  id            String   @id @default(cuid())
  farmerId      String
  name          String
  culture       String
  superficie    Float
  lat           Float
  lng           Float
  ndvi          Float
  statut        String
  polygone       String?
  stade          String?
  datePlantation DateTime?
  historique     String?
  lastUpdatedAt  DateTime  @updatedAt

  farmer      Farmer       @relation(fields: [farmerId], references: [id])
  alerts      Alert[]
  iotReadings IoTReading[]
  weatherHistory WeatherHistory[]
  activities  Activity[]
}

model CreditScore {
  id                      String   @id @default(cuid())
  farmerId                String   @unique
  score                   Int
  scoreMax                Int
  status                  String
  historiquePayments      Float
  utilisationCredit       Float
  diversificationCultures Float
  regulariteDeclarations  Float
  riskLevel               RiskLevel
  generatedAt             DateTime @default(now())

  farmer Farmer @relation(fields: [farmerId], references: [id])
}

model Loan {
  id                  String     @id @default(cuid())
  farmerId            String
  type                String
  montantInitial      Float
  montantRembourse    Float
  tauxAnnuel          Float
  status              LoanStatus
  nextPaymentDate     DateTime
  nextPaymentAmount   Float
  createdAt           DateTime   @default(now())

  farmer       Farmer        @relation(fields: [farmerId], references: [id])
  transactions Transaction[]
}

model Transaction {
  id          String   @id @default(cuid())
  loanId      String
  date        DateTime
  description String
  amount      Float
  isCredit    Boolean

  loan Loan @relation(fields: [loanId], references: [id])
}

model Alert {
  id         String   @id @default(cuid())
  farmerId   String?
  coopId     String?
  parcelleId String?
  type       String
  severity   String
  title      String
  message    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  farmer      Farmer?      @relation(fields: [farmerId], references: [id])
  cooperative Cooperative? @relation(fields: [coopId], references: [id])
  parcelle    Parcelle?    @relation(fields: [parcelleId], references: [id])

  @@index([farmerId, read])
  @@index([coopId, read])
}

model IoTNode {
  id            String     @id @default(cuid())
  nodeCode      String     @unique
  cooperativeId String?    @unique
  farmerId      String?
  lat           Float
  lng           Float
  status        NodeStatus
  batterie      Float
  connectivity  String
  lastSyncAt    DateTime
  siteId        String?
  subteamId     String?
  altitude      Float?
  lastRssi      Int?
  totalReadings Int        @default(0)

  cooperative Cooperative? @relation(fields: [cooperativeId], references: [id])
  farmer      Farmer?      @relation(fields: [farmerId], references: [id])
  readings    IoTReading[]
}

model IoTReading {
  id           String   @id @default(cuid())
  nodeId       String
  parcelleId   String?
  temperature  Float
  humidity     Float
  soilMoisture Float?
  rainfall     Float?
  luminosity   Float?
  phSol        Float?
  recordedAt   DateTime @default(now())

  // Air sensors (DHT22 x2)
  tempS1          Float?
  humidityS1      Float?
  tempS2          Float?
  humidityS2Raw   Float?
  humidityS2Corr  Float?
  tempAvg         Float?
  humidityAvg     Float?
  humidityUsed    Float?
  humidityDiff    Float?

  // Soil (DS18B20 + analog)
  soilTempTrue    Float?
  soilRaw         Int?
  soilVoltage     Float?

  // Device metadata
  rssi            Int?
  deviceCode      String?
  ntpSynced       Boolean?

  node     IoTNode   @relation(fields: [nodeId], references: [id])
  parcelle Parcelle? @relation(fields: [parcelleId], references: [id])
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  key         String    @unique
  permissions String[]
  createdAt   DateTime  @default(now())
  lastUsed    DateTime?
  status      String
  userId      String

  user User @relation(fields: [userId], references: [id])
}

model WeatherHistory {
  id          String   @id @default(cuid())
  parcelleId  String?
  coopId      String?
  farmerId    String?
  lat         Float
  lng         Float
  region      String?
  country     String   @default("CI")
  recordedAt  DateTime @default(now())

  // Temperature
  tempAir     Float
  tempFeels   Float?
  tempSoil0   Float?
  tempSoil6   Float?
  tempSoil18  Float?
  tempSoil54  Float?

  // Humidity
  humidityAir    Float?
  soilMoist0     Float?
  soilMoist1     Float?
  soilMoist3     Float?
  soilMoist9     Float?
  soilMoist27    Float?

  // Weather
  precipitation  Float?
  precipProb     Float?
  windSpeed      Float?
  windDir        Float?
  cloudCover     Float?

  // Solar
  radiation      Float?
  uvIndex        Float?
  sunshineDur    Float?

  // Agricultural
  et0            Float?
  vpd            Float?
  dewPoint       Float?

  // Relations
  parcelle    Parcelle?    @relation(fields: [parcelleId], references: [id])
  cooperative Cooperative? @relation(fields: [coopId], references: [id])
  farmer      Farmer?      @relation(fields: [farmerId], references: [id])

  @@index([parcelleId, recordedAt])
  @@index([coopId, recordedAt])
  @@index([farmerId, recordedAt])
  @@index([lat, lng, recordedAt])
}

model Activity {
  id          String   @id @default(cuid())
  farmerId    String
  parcelleId  String?
  type        String
  description String?
  date        DateTime
  statut      String   @default("EN_COURS")
  createdAt   DateTime @default(now())

  farmer   Farmer    @relation(fields: [farmerId], references: [id])
  parcelle Parcelle? @relation(fields: [parcelleId], references: [id])
}

model IotKitRequest {
  id             String   @id @default(cuid())
  coopId         String?
  coopName       String
  superficie     Float?
  culture        String?
  nbMembres      Int?
  hasElectricite Boolean  @default(false)
  hasConnexion   Boolean  @default(false)
  message        String?
  statut         String   @default("PENDING")
  createdAt      DateTime @default(now())
}

model CreditRequest {
  id             String   @id @default(cuid())
  farmerId       String
  coopId         String?
  montant        Float
  duree          Int
  objet          String
  message        String?
  statut         String   @default("EN_ATTENTE")
  montantAccorde Float?
  taux           Float?
  dureeAccordee  Int?
  motif          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  farmer Farmer @relation(fields: [farmerId], references: [id])
}

model Institution {
  id        String   @id @default(cuid())
  name      String
  type      String
  country   String   @default("CI")
  logo      String?
  modules   String[]
  plan      String   @default("STANDARD")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  users         InstitutionUser[]
  decisions     CreditDecision[]
  scoringConfig InstitutionScoringConfig?
  cooperatives  Cooperative[]
}

model InstitutionUser {
  id            String      @id @default(cuid())
  userId        String
  institutionId String
  role          String      @default("ANALYST")
  createdAt     DateTime    @default(now())

  user        User        @relation(fields: [userId], references: [id])
  institution Institution @relation(fields: [institutionId], references: [id])

  @@unique([userId, institutionId])
}

model CreditDecision {
  id            String   @id @default(cuid())
  institutionId String
  farmerId      String
  montant       Float?
  taux          Float?
  duree         Int?
  statut        String
  motif         String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id])
  farmer      Farmer      @relation(fields: [farmerId], references: [id])
}

model InstitutionScoringConfig {
  id            String      @id @default(cuid())
  institutionId String      @unique
  institution   Institution @relation(fields: [institutionId], references: [id])

  weightC1      Float    @default(30)
  weightC2      Float    @default(25)
  weightC3      Float    @default(25)
  weightC4      Float    @default(20)

  c1Rules          Json?
  c2Rules          Json?
  c3Rules          Json?
  c4Rules          Json?
  products         Json?
  creditConditions Json?
  riskProfile      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id            String   @id @default(cuid())
  farmerId      String
  cooperativeId String
  objet         String
  message       String
  lu            Boolean  @default(false)
  createdAt     DateTime @default(now())

  farmer      Farmer      @relation(fields: [farmerId], references: [id])
  cooperative Cooperative @relation(fields: [cooperativeId], references: [id])
}
