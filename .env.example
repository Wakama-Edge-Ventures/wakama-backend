# Core backend
DATABASE_URL=
JWT_SECRET=
PORT=4000

# Country/timezone defaults
DEFAULT_COUNTRY=CI
CI_TIMEZONE=Africa/Abidjan
MOROCCO_TIMEZONE=Africa/Casablanca

# Optional CORS extension
CORS_ALLOWED_ORIGINS=

# Upload + limits
UPLOAD_MAX_BYTES=5242880
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW=60000
AUTH_RATE_LIMIT_MAX=10
UPLOAD_RATE_LIMIT_MAX=20
IOT_RATE_LIMIT_MAX=600

# NDVI/Copernicus
SENTINEL_CLIENT_ID=
SENTINEL_CLIENT_SECRET=

# Evidence/IPFS/Solana (backend only)
# Never expose these values to frontend applications.
# Anchoring is asynchronous and non-blocking for business flows.
# Use devnet for dev/demo; switch to mainnet-beta only with production approval.
PINATA_JWT=
PINATA_GATEWAY_URL=https://gateway.pinata.cloud/ipfs/
IPFS_GATEWAY_URL=
SOLANA_WALLET_PRIVATE_KEY=
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=
ANCHORING_ENABLED=false
PINATA_UPLOAD_ENABLED=false
